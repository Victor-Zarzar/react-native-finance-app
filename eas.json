{
	"cli": {
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"node": "24.14.0"
		},

		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development",
			"ios": {
				"simulator": true,
				"resourceClass": "m-medium"
			},
			"android": {
				"buildType": "apk"
			}
		},

		"preview": {
			"extends": "base",
			"distribution": "internal",
			"channel": "preview",
			"ios": {
				"resourceClass": "m-medium"
			},
			"android": {
				"buildType": "apk"
			}
		},

		"production": {
			"extends": "base",
			"channel": "production",
			"autoIncrement": true,
			"ios": {
				"resourceClass": "m-medium"
			},
			"android": {
				"buildType": "app-bundle"
			}
		}
	},
	"submit": {
		"production": {}
	}
}

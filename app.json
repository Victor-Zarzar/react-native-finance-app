{
	"expo": {
		"name": "react-native-finance-app",
		"slug": "react-native-finance-app",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "react-native-finance-app",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"splash": {
			"image": "./assets/images/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"assetBundlePatterns": ["**/*"],
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"edgeToEdgeEnabled": true,
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			}
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			"expo-localization",
			[
				"expo-file-system",
				{
					"supportsOpeningDocumentsInPlace": true,
					"enableFileSharing": true
				}
			],
			[
				"expo-sqlite",
				{
					"enableFTS": true,
					"useSQLCipher": true,
					"android": {
						"enableFTS": false,
						"useSQLCipher": false
					},
					"ios": {
						"customBuildFlags": [
							"-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
						]
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		}
	}
}
